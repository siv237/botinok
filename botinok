#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PY="$SCRIPT_DIR/venv/bin/python"
APP="$SCRIPT_DIR/botinok.py"
REQ="$SCRIPT_DIR/requirements.txt"

if [[ ! -x "$PY" ]]; then
  echo "Error: venv python not found/executable: $PY" >&2
  echo "Create venv or adjust launcher." >&2
  exit 1
fi

if [[ "${1:-}" == "--update-packages" || "${1:-}" == "-U" ]]; then
  if [[ ! -f "$REQ" ]]; then
    echo "Error: requirements.txt not found: $REQ" >&2
    exit 1
  fi
  exec "$PY" -m pip install --upgrade pip setuptools wheel -r "$REQ"
fi

exec "$PY" "$APP" "$@"
